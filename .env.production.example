# ====================
# ProTrack — Production
# ====================
# Copy ke .env, lalu isi sesuai server production.
# JANGAN commit file .env ke git.

# --- Application ---
APP_NAME=ProTrack
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://protrack.example.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_TIMEZONE=Asia/Jakarta

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# --- Logging ---
LOG_CHANNEL=daily
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_DAILY_DAYS=30

# --- Database ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=protrack
DB_USERNAME=protrack
DB_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT

# --- Session ---
SESSION_DRIVER=database
SESSION_LIFETIME=1440
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# --- Broadcasting & Queue (Phase 4.5+ Reverb) ---
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# --- Cache ---
CACHE_STORE=database
# CACHE_STORE=redis    # rekomendasi kalau Redis available

# --- Redis (opsional, untuk cache/queue performa lebih baik) ---
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail (untuk reset password, dll) ---
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@protrack.example.com
MAIL_FROM_NAME="${APP_NAME}"

# --- Integrasi pihak ke-3 ---
# Catatan: API keys ini sebenarnya di-store di tabel `system_settings`
# (terenkripsi) lewat halaman Pengaturan → Integrasi.
# Variabel .env ini hanya untuk fallback / initial bootstrap.

# Sidobe WhatsApp Gateway
SIDOBE_API_URL=
SIDOBE_API_KEY=

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# Gemini AI (comma-separated multi-key untuk load balancing)
GEMINI_API_KEYS=

# --- Trusted Proxies (jika di belakang load balancer/CloudFlare) ---
# TRUSTED_PROXIES=*
